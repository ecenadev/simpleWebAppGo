{{template "base" .}}

{{define "content"}}

<div class="row g-5">
        <div class="col-md-8">
          <div class="row g-5">
            <div class="col">
              <h1 class="mt-3">Make new Post</h1>

              {{$res := index .Data "article" }}

                <form action="/makepost" method="post" class="" novalidate>
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <div class="form-group mt-3">
                  <label for="blog_title">Title:</label>
                  {{with .Form.Errors.GetError "blog_title"}}
                   <label for="" class="text-danger">{{.}}</label>
                  {{end}}
                  <input
                    type="text"
                    class="form-control"
                    id="blog_title"
                    autocomplete="off"
                    name="blog_title"
                    value="{{$res.BlogTitle}}"
                    required
                  />
                </div>
                <div class="form-group">
                  {{with .Form.Errors.GetError "blog_article"}}
                   <label for="" class="text-danger">{{.}}</label>
                  {{end}}
                  <label for="blog_article">Article:</label>
                  <textarea
                    type="text"
                    class="form-control"
                    id="blog_article"
                    autocomplete="off"
                    name="blog_article"
                    value="{{$res.BlogArticle}}"
                    required
                    rows="15"
                  ></textarea>
                </div>

                <hr />
                <input
                  type="submit"
                  class="btn btn-primary"
                  value="Submit Blog Post"
                />
              </form>
            </div>
          </div>
          </div>
          </div>
          </div>


{{end}}